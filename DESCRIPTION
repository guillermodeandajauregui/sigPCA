Package: sigPCA
Title: Statistical Significance Testing for Principal Components
Version: 0.1.0
Authors@R: c(
    person(
      given = "Guillermo",
      family = "de Anda-Jáuregui",
      email = "gdeanda@inmegen.edu.mx",
      role = c("aut", "cre", "cph")
    ),
